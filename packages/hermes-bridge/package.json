{
  "name": "@hermes/bridge",
  "version": "1.0.0-preview.1",
  "description": "TypeScript bridge for Hermes desktop framework - C# ↔ JS interop",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mythetech/Hermes.git",
    "directory": "packages/hermes-bridge"
  },
  "keywords": [
    "hermes",
    "desktop",
    "webview",
    "interop",
    "bridge",
    "electron-alternative"
  ]
}
