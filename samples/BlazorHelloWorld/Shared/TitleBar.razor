@inject HermesWindow Window

<HermesTitleBar Height="38">
    <div class="title-bar-content">
        <span class="title-bar-brand">Hermes</span>
        <span class="title-bar-title">@Window.Title</span>
    </div>

    <div class="title-bar-spacer"></div>

    <div class="title-bar-actions">
        <button class="action-btn" @onclick="HandleTestClick" title="Test Button">
            Test (@_clickCount)
        </button>
    </div>
</HermesTitleBar>

@code {
    private int _clickCount;

    private void HandleTestClick()
    {
        _clickCount++;
        Console.WriteLine($"Title bar button clicked! Count: {_clickCount}");
    }
}
