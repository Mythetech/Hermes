@page "/"
@using Hermes.Blazor.Diagnostics
@inject TestContext Context

<FluentStack Orientation="Orientation.Vertical" VerticalGap="20">
    <FluentCard>
        <h1>Hermes Integration Tests</h1>
        <p>This application tests various Hermes features including:</p>
        <ul>
            <li><strong>JS Module Loading</strong> - Fluent UI Blazor components</li>
            <li><strong>Custom Titlebar</strong> - Drag regions and window controls</li>
            <li><strong>Native Menus</strong> - Menu creation and accelerators</li>
            <li><strong>Window Management</strong> - Size, position, maximize/restore</li>
        </ul>
    </FluentCard>

    <FluentCard>
        <h2>Test Status</h2>
        @if (Context.IsIntegrationTest)
        {
            <FluentBadge Appearance="Appearance.Accent">Integration Test Mode</FluentBadge>
            @if (Context.AutoExit)
            {
                <FluentBadge>Auto Exit Enabled</FluentBadge>
            }
        }
        else
        {
            <FluentBadge>Manual Mode</FluentBadge>
            <p>Set <code>HERMES_INTEGRATION_TEST=1</code> to enable automated tests.</p>
        }
    </FluentCard>

    <FluentCard>
        <h2>First Render</h2>
        @if (_firstRenderReported)
        {
            <p>First render completed successfully.</p>
            <FluentBadge Appearance="Appearance.Accent">@($"{_renderTime.TotalMilliseconds:F1}ms")</FluentBadge>
        }
        else
        {
            <FluentProgressRing />
        }
    </FluentCard>
</FluentStack>

@code {
    private TimeSpan _renderTime;
    private bool _firstRenderReported;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _renderTime = TimeSpan.FromMilliseconds(100); // Placeholder
            _firstRenderReported = true;

            // Report to smoke test infrastructure
            SmokeTestReporter.ReportFirstRender(_renderTime.TotalMilliseconds);

            // Report JS module loading test (Fluent UI uses JS interop)
            TestReporter.Start("blazor-first-render");
            TestReporter.Pass("blazor-first-render");

            StateHasChanged();
        }
    }
}
