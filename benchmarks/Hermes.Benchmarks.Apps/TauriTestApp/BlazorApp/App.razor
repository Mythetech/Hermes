@inject IJSRuntime JS

<div class="ready">
    <h1>READY</h1>
    <p>First render: @_renderTime ms</p>
</div>

@code {
    private double _renderTime;
    private bool _rendered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_rendered)
        {
            _rendered = true;

            // Get the elapsed time from performance.now() which starts when the page loads
            _renderTime = await JS.InvokeAsync<double>("getElapsedTime");

            // Call Tauri command to print to stdout
            try
            {
                await JS.InvokeVoidAsync("invokeTauri", _renderTime);
            }
            catch
            {
                // Fallback for non-Tauri environments (debugging)
                Console.WriteLine($"BENCHMARK_READY:{_renderTime:F2}");
            }

            StateHasChanged();
        }
    }
}
