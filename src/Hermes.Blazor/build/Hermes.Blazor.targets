<Project>
  <!--
    This targets file is included in the Mythetech.Hermes.Blazor NuGet package.
    It copies static web assets from NuGet packages to the output wwwroot folder
    for desktop Blazor apps where the development-time paths don't exist.
  -->

  <!-- For build scenario -->
  <Target Name="HermesCopyStaticWebAssetsToOutput"
          AfterTargets="GenerateStaticWebAssetsManifest"
          Condition="'$(PublishDir)' == ''">

    <PropertyGroup>
      <_HermesWwwrootPath>$([MSBuild]::NormalizePath($(OutputPath), 'wwwroot'))</_HermesWwwrootPath>
    </PropertyGroup>

    <ItemGroup>
      <_HermesContentAssetsToCopy Include="@(StaticWebAsset)"
                                   Condition="$([System.String]::Copy('%(BasePath)').StartsWith('_content'))" />
    </ItemGroup>

    <ItemGroup>
      <_HermesContentAssetsToCopy>
        <DestinationPath>$([MSBuild]::NormalizePath($(_HermesWwwrootPath), %(BasePath), %(Filename)%(Extension)))</DestinationPath>
      </_HermesContentAssetsToCopy>
    </ItemGroup>

    <Copy SourceFiles="@(_HermesContentAssetsToCopy)"
          DestinationFiles="@(_HermesContentAssetsToCopy->'%(DestinationPath)')"
          SkipUnchangedFiles="true"
          Condition="'@(_HermesContentAssetsToCopy)' != ''" />
  </Target>

  <!-- For publish scenario -->
  <Target Name="HermesCopyStaticWebAssetsToPublish"
          AfterTargets="GenerateStaticWebAssetsManifest"
          Condition="'$(PublishDir)' != ''">

    <PropertyGroup>
      <_HermesWwwrootPath>$([MSBuild]::NormalizePath($(PublishDir), 'wwwroot'))</_HermesWwwrootPath>
    </PropertyGroup>

    <ItemGroup>
      <_HermesContentAssetsToCopy Include="@(StaticWebAsset)"
                                   Condition="$([System.String]::Copy('%(BasePath)').StartsWith('_content'))" />
    </ItemGroup>

    <ItemGroup>
      <_HermesContentAssetsToCopy>
        <DestinationPath>$([MSBuild]::NormalizePath($(_HermesWwwrootPath), %(BasePath), %(Filename)%(Extension)))</DestinationPath>
      </_HermesContentAssetsToCopy>
    </ItemGroup>

    <Copy SourceFiles="@(_HermesContentAssetsToCopy)"
          DestinationFiles="@(_HermesContentAssetsToCopy->'%(DestinationPath)')"
          SkipUnchangedFiles="true"
          Condition="'@(_HermesContentAssetsToCopy)' != ''" />
  </Target>
</Project>
